{
  "name": "kanabun",
  "version": "0.0.0",
  "private": true,
  "description": "A Svelte-flavoured frontend framework built on Bun + TypeScript, with zero runtime dependencies.",
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "typecheck": "bunx tsc --noEmit",
    "pub": "bun run scripts/publish.ts",
    "pub:dry": "bun run scripts/publish.ts --dry-run"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
