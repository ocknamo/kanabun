{
  "name": "kanabun",
  "version": "0.0.1",
  "private": true,
  "description": "A Svelte-flavoured frontend framework built on Bun + TypeScript, with zero runtime dependencies.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/ocknamo/kanabun#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ocknamo/kanabun.git"
  },
  "bugs": {
    "url": "https://github.com/ocknamo/kanabun/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "typecheck": "bunx tsc --noEmit",
    "pub": "bun run scripts/publish.ts",
    "pub:dry": "bun run scripts/publish.ts --dry-run"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "typescript": "6.0.2"
  }
}
